        [{ "node": "Send Team Notification",    "type": "main", "index": 0 }]
      ]
    },
    "Send Team Notification": {
      "main": [
        [{ "node": "Build Execution Telemetry", "type": "main", "index": 0 }]
      ]
    },
    "Build Execution Telemetry": {
      "main": [
        [{ "node": "Soch Ops Telemetry",        "type": "main", "index": 0 }]
      ]
