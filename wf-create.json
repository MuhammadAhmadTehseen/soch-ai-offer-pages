{
  "name": "Soch Academy — Lead Capture",
  "nodes": [
    {
      "id": "b1000000-0001-0001-0001-000000000001",
      "name": "Academy Lead Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "academy-lead",
        "responseMode": "immediately",
        "options": {}
      }
    },
    {
      "id": "b1000000-0002-0002-0002-000000000002",
      "name": "Capture Start Time",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [440, 140],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
