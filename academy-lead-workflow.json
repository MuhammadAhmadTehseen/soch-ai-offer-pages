bmitted</td>\n        <td style=\"padding:10px 0\">{{ $json.submittedAt }}</td>\n      </tr>\n    </table>\n    <div style=\"margin:24px 0 0;padding:16px 20px;background:#fff;border-radius:6px;border:1px solid #e5e2db\">\n      <p style=\"margin:0 0 8px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#103129\">LinkedIn Search</p>\n      <a href=\"{{ $json.linkedinSearchUrl }}\" style=\"color:#ff5c35;font-size:14px\">Search Google for their LinkedIn →</a>\n    </div>\n  </div>\n  <div style=\"background:#103129;padding:14px 32px;text-align:center\">\n    <p style=\"color:rgba(255,255,255,0.4);font-size:11px;margin:0\">Soch Academy Lead Capture · auto-generated</p>\n  </div>\n</div>",
        "options": { "appendAttribution": false }
      },
      "credentials": {
        "gmailOAuth2": { "id": "2ReudJzZxClQfp1R", "name": "Gmail account" }
      },
      "onError": "continueRegularOutput"
