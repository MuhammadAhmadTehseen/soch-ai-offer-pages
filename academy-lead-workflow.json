    {
      "id": "acad-tel-01",
      "name": "Build Execution Telemetry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 460],
      "parameters": {
        "jsCode": "const startTime = $('Capture Start Time').first().json.execution_start;\nconst now = Date.now();\nreturn [{ json: {\n  log_type: 'execution',\n  workflow_name: 'Soch Academy — Lead Capture',\n  workflow_id: $workflow.id,\n  execution_id: $execution.id,\n  status: 'success',\n  started_at: new Date(startTime).toISOString(),\n  finished_at: new Date(now).toISOString(),\n  duration_ms: now - startTime,\n  execution_url: `https://sochconsulting.app.n8n.cloud/workflow/${$workflow.id}/executions/${$execution.id}`\n}}];"
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "acad-tel-02",
      "name": "Soch Ops Telemetry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 460],
      "parameters": {
        "method": "POST",
        "url": "https://script.google.com/macros/s/AKfycbyNL_efegD34j44pUh_W2fUUEDpx3Yk0WNYN0Y2ayA6MMRHq9ZmeyKC5LhenTvCQWK4Ag/exec",
        "sendBody": true,
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "log_type",      "value": "={{ $json.log_type }}" },
            { "name": "workflow_name", "value": "={{ $json.workflow_name }}" },
            { "name": "workflow_id",   "value": "={{ $json.workflow_id }}" },
            { "name": "execution_id",  "value": "={{ $json.execution_id }}" },
            { "name": "status",        "value": "={{ $json.status }}" },
            { "name": "started_at",    "value": "={{ $json.started_at }}" },
            { "name": "finished_at",   "value": "={{ $json.finished_at }}" },
            { "name": "duration_ms",   "value": "={{ $json.duration_ms }}" },
            { "name": "execution_url", "value": "={{ $json.execution_url }}" }
          ]
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "Academy Lead Webhook": {
