        "message": "<div style=\"font-family:Inter,Arial,sans-serif;max-width:600px;margin:0 auto;color:#171814\">\n  <div style=\"background:#103129;padding:28px 40px\">\n    <img src=\"https://academywithsochcom.vercel.app/assets/logo-lockup.png\" alt=\"Soch\" style=\"height:28px\">\n  </div>\n  <div style=\"padding:40px;background:#fbf8f2\">\n    <h2 style=\"color:#103129;font-size:22px;margin:0 0 20px;font-weight:700\">We've got your enquiry.</h2>\n    <p style=\"font-size:15px;line-height:1.7;margin:0 0 16px\">Hi {{ $('Academy Lead Webhook').first().json.body.name }},</p>\n    <p style=\"font-size:15px;line-height:1.7;margin:0 0 20px\">Thanks for reaching out about the <strong>{{ $('Academy Lead Webhook').first().json.body.track }}</strong>. We've received your details and will review them shortly.</p>\n    <div style=\"background:#fff;border-left:4px solid #ff5c35;padding:18px 22px;margin:0 0 24px;border-radius:0 6px 6px 0\">\n      <p style=\"margin:0 0 6px;font-size:12px;color:#103129;font-weight:700;text-transform:uppercase;letter-spacing:0.06em\">What happens next</p>\n      <p style=\"margin:0;font-size:15px;line-height:1.6\">Within <strong>two business days</strong> our team will reach out with a few scoping questions — then we'll give you an exact, flat price for your firm.</p>\n    </div>\n    <p style=\"font-size:15px;line-height:1.7;margin:0 0 16px\">Questions in the meantime? Reply to this email or write to <a href=\"mailto:hello@withsoch.com\" style=\"color:#ff5c35\">hello@withsoch.com</a>.</p>\n    <p style=\"font-size:15px;margin:0\">— The Soch team</p>\n  </div>\n  <div style=\"background:#103129;padding:16px 40px;text-align:center\">\n    <p style=\"color:rgba(255,255,255,0.4);font-size:11px;margin:0\">© 2026 Soch. All rights reserved.</p>\n  </div>\n</div>",
        "options": { "appendAttribution": false }
      },
      "credentials": {
        "gmailOAuth2": { "id": "2ReudJzZxClQfp1R", "name": "Gmail account" }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "acad-bn-01",
      "name": "Build Team Notification",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [440, 460],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
            { "name": "name",     "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.name }}" },
            { "name": "email",    "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.email }}" },
            { "name": "company",  "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.company }}" },
            { "name": "teamSize", "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.teamSize }}" },
            { "name": "track",    "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.track }}" },
            { "name": "notes",    "type": "stringValue", "value": "={{ $('Academy Lead Webhook').first().json.body.message || '—' }}" },
