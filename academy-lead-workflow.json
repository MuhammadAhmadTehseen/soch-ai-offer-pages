            { "name": "submittedAt", "type": "stringValue", "value": "={{ $now.setZone('Asia/Karachi').toFormat('cccc dd LLL yyyy, hh:mm a') + ' PKT' }}" }
          ]
        }
      }
    },
    {
      "id": "acad-tm-01",
      "name": "Send Team Notification",
